set -e  # exit on error
echo "pwf-cleanup: ENTRY"

function print_help {
	cat <<'EOF'
USAGE
    pwf-cleanup [OPTION...] [PATH]

OPTIONS
    -h     show this help
    -u     undo cleanup - by latest found tar file

INFO
    Cleanup given folder according to following list:
        * If folder is inside 1_original/: Error, nothing to cleanup
        * If folder is an event folder insidde 2_lab/: Put a list of preview
          files plus links to original files into a tar.bz2 archive to save 
          space and reduce the number of files on the HD. This step is
          reversible by the -u option.

    A PATH can be specified either by by normal means of bash or by using the
    FZF tool. Write 

        pwf-cleanup **<tab>

    to bring the FZF tool to front where you can select the desired path much
    faster. Paths are automatically bound to the pwf folder structure, so the
    check tool can be used from anywhere. If no PATH is specified, the current
    directory will be taken.
EOF
}

UNDO=false

while getopts 'hu' OPTION; do
    case "$OPTION" in
        h) print_help; exit 0 ;;
        u) UNDO=true ;;
        *) print_help; exit 1 ;;
    esac
done

# make up $DIR variable:
DIR=${@:$OPTIND:1}
[[ ! "$DIR" ]] && DIR=$(pwd)
[[ -e "$DIR" ]] || (>&2 echo "ERROR: \"$DIR\" does not exist!" && exit 1)
[[ -d "$DIR" ]] || (>&2 echo "ERROR: PATH must be a directory!" && exit 1)

pwf-check -o name "$DIR" > /dev/null

if [[ "$DIR" == *"1_original"* ]]; then
    >&2 echo "ERROR: Nothing to cleanup in 1_original folder tree!"
    exit 1

elif [[ "$DIR" == *"2_lab"* ]]; then
    if [[ ! "$(basename $(dirname "$DIR"))" =~ ^[0-9]{4}$ ]]; then
        >&2 echo "ERROR: PATH must be an event directory!"
        exit 1
    fi

    if [[ $UNDO == false ]]; then
        ls -1 "$DIR/1_preview/" > "$DIR/1_preview_files.txt"
        archive="lab-$(date +%Y%m%d-%H%M%S).tar.bz2"
        echo "Creating tar archive: $archive"
        (cd $DIR && \
            tar cjf $archive 1_preview_files.txt 2_original_* && \
            rm -r 1_preview &&
            rm 1_preview_files.txt &&
            rm -r 2_original_*)
    else  # UNDO
        #
        # TODO: make this whole undo code more robust!
        #
        TAR_FILE=$(find "$DIR" -maxdepth 1 -name "lab-*.tar.bz2" | sort | tail -1)
        if [[ ! -e "$TAR_FILE" ]]; then
            >&2 echo "ERROR: no tar file found!"
            exit 1
        fi

        echo "Extracting $TAR_FILE..."
        (cd $DIR && tar xjf $(basename $TAR_FILE))

        echo "Restoring preview files..."
        ORIG_DIR=$(echo "$DIR" | sed -e s/2_lab/1_original/)
        pwf-prepare-lab "$ORIG_DIR"
        for f in $(find "$DIR/1_preview/" -maxdepth 1 -type f); do
            grep -q "$(basename $f)" "$DIR/1_preview_files.txt" || rm $f
        done
    fi
fi

echo "pwf-cleanup: OK"
