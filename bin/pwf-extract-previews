set -e  # exit on any error
shopt -s nullglob  # no error when glob has no match
echo "pwf-extract-previews: ENTRY"

print_help () {
	cat <<'EOF'
USAGE
    pwf-extract-previews [OPTION...] [PATH]

OPTIONS
    -h     show this help
    -o     directory to put preview files into (default is given PATH)
    -l     put previews into a Lab folder (into 1_preview/ subfolder)
    -r     recursively seach through subdirectories of given PATH
    -f     provide filter-file to only generate previews of listed files

INFO
    Creates small preview images out of RAW and JPG files. For RAW files, the
    preview images are extracted from the exif info. For JPG files, a smaller
    version of the original is created.

    The option -l can be used to prepare a Lab folder, given that the PATH is
    pointing to an event folder in the 1_original/ structure.

    A PATH can be specified either by by normal means of bash or by using the
    FZF tool. Write 

        pwf-extract-previews **<tab>

    to bring the FZF tool to front where you can select the desired path much
    faster. Paths are automatically bound to the pwf folder structure, so the
    check tool can be used from anywhere. If no PATH is specified, the current
    directory will be taken.
EOF
}

OUT_DIR=
LAB=false
RECURSIVE=false
FILTER_FILE=

while getopts 'ho:lrf:' OPTION; do
	case "$OPTION" in
		h) print_help; exit 0 ;;
        o) OUT_DIR="$OPTARG" ;;
        l) LAB=true && RECURSIVE=true ;;
        r) RECURSIVE=true ;;
        f) FILTER_FILE="$OPTARG" ;;
		*) print_help; exit 1 ;;
	esac
done

# make up $DIR variable:
DIR=${@:$OPTIND:1}
[[ ! "$DIR" ]] && DIR="."
[[ -e "$DIR" ]] || _pwf_err_exit "\"$DIR\" does not exist!"

# perform precondition checks:
[[ "$OUT_DIR" && "$LAB" == true ]] && \
    _pwf_err_exit "options -o and -l cannot be combined!"
pwf-check -o name "$DIR" > /dev/null || exit 1
[[ "$FILTER_FILE" && ! -f "$FILTER_FILE" ]] && \
    _pwf_err_exit "provided filter file not found!"

# define output directory:
if [[ ! "$OUT_DIR" ]]; then
    if [[ "$LAB" == false ]]; then
        # if $DIR is a file, adapt:
        [[ -d "$DIR" ]] && OUT_DIR="$DIR" || OUT_DIR=$(dirname "$DIR")
    else  # LAB
        _pwf_is_event_dir "$DIR" || \
            _pwf_err_exit "PATH must be an event dir in 1_original/ tree!"
        OUT_DIR="${DIR/1_original/2_lab}/1_preview"
        mkdir -p "$OUT_DIR"
    fi
fi

[[ -d "$OUT_DIR" ]] || _pwf_err_exit "output directory does not exist!"

[[ "$RECURSIVE" == true ]] && shopt -s globstar

# RAW files...
for f in "$DIR"/**/*.{NEF,NRW,CR2}; do
    f_name=$(basename "$f")
    [[ "$FILTER_FILE" != "" ]] && grep -q "$f_name" "$FILTER_FILE" || continue
    tmp_file="/tmp/${f_name%.*}-preview3.jpg"
    preview_file="$OUT_DIR/$f_name-preview.jpg"

    # ignore already existing previews
    [[ -f "$preview_file" ]] && continue

    echo "$f"

    orientation=$(exiv2 -Pv -g Exif.Image.Orientation "$f")
    date=$(exiv2 -Pv -g Exif.Photo.DateTimeOriginal "$f")

    exiv2 -ep3 -l/tmp -f "$f"  # creates "$tmp_file"

    exiv2 -M"set Exif.Image.Orientation $orientation" "$tmp_file"
    exiv2 -M"set Exif.Photo.DateTimeOriginal $date" "$tmp_file"

    convert -filter Sinc -resize 'x1080>' -quality 85 "$tmp_file" "$preview_file"
done

# JPG files...
for f in "$DIR"/**/*.{jpg,JPG,jpeg,JPEG}; do
    # NOTE: jpegs have usually no preview embedded, so we just create a 
    # resized version of the originals
 
    f_name=$(basename "$f")
    [[ "$FILTER_FILE" != "" ]] && grep -q "$f_name" "$FILTER_FILE" || continue
    preview_file="$OUT_DIR/${f_name}-preview.jpg"

    # ignore already existing previews
    [[ -f "$preview_file" ]] && continue

    echo "$f"

    convert -filter Sinc -resize 'x1080>' -quality 85 "$f" "$preview_file"
done

echo "pwf-extract-previews: OK"
