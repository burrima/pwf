    check tool can be used from anywhere. If no PATH is specified, the current
    directory will be taken.
EOF
}

LINK_ALL=false

while getopts 'ha' OPTION; do
    case "$OPTION" in
        h) print_help; exit 0 ;;
        a) LINK_ALL=true ;;
        *) print_help; exit 1 ;;
    esac
