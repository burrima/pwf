set -e  # exit on any error
shopt -s nullglob  # no error when glob has no match
echo "pwf-link: ENTRY"

function print_help {
	cat <<'EOF'
USAGE
    pwf-link [OPTION...] SOURCE TARGET
    pwf-link -l [OPTION...] SOURCE

OPTIONS
    -a     link all source files to lab, independent of preview existance
    -h     show this help

INFO
    Links SOURCE file(s) into the TARGET directory.

    If option -l is provided then the raw, jpg, audio and video files of the
    given SOURCE event folder (in 1_original/ tree) are linked into the TARGET
    event folder (in 2_lab/ tree) to corresponding 2_original_ sub-folders.
    Files are then only linked if the 1_preview/ folder contains corresponding
    preview file (use option -a to omit this feature).

    A path can be specified either by by normal means of bash or by using the
    FZF tool. Write 

        pwf-prepare-lab **<tab>

    to bring the FZF tool to front where you can select the desired path much
    faster. Paths are automatically bound to the pwf folder structure, so the
    check tool can be used from anywhere. If no PATH is specified, the current
    directory will be taken.
EOF
}

LAB=false
LINK_ALL=false

while getopts 'hal' OPTION; do
    case "$OPTION" in
        h) print_help; exit 0 ;;
        a) LINK_ALL=true ;;
        l) LAB=true ;;
        *) print_help; exit 1 ;;
    esac
done

# make up source and target variables:
SOURCE=${@:$OPTIND:1}
TARGET=${@:$OPTIND+1:2}
[[ -e "$SOURCE" ]] || _pwf_err_exit "source \"$SOURCE\" does not exist!"
[[ "$LAB" == true && "$TARGET" ]] && _pwf_err_exit "no TARGET allowed with -l"

# perform precondition checks:
pwf-check -o name "$SOURCE" > /dev/null || exit 1

# special feature: link originals to lab folder:
if [[ "$LAB" == true ]]; then
    _pwf_is_event_dir "$SOURCE" || \
        _pwf_err_exit "SOURCE must be an event dir in 1_original/ tree!"
    TARGET="${SOURCE/1_original/2_lab}"

    echo "Link originals to lab..."
    for t in raw jpg; do
        [[ -e "$SOURCE/$t" ]] || continue
        if [[ -e "$TARGET/2_original_$t" ]]; then
            echo "2_original_$t exists, skipping it"
            continue
        fi
        for f in "$SOURCE"/$t/*; do
            trunc=$(basename $f)
            trunc=${trunc%.*}
            if [[ "$LINK_ALL" == false && ! $(find "$TARGET/1_preview/" -name "*$trunc*") ]]; then
                echo "Ignore $(basename $f) - no preview existing"
                continue
            fi
            mkdir -p "$TARGET/2_original_$t"
            ln -s -r "$f" "$TARGET/2_original_$t/"
        done
    done
    for t in video audio; do
        [[ -e "$SOURCE/$t" ]] || continue
        if [[ -e "$TARGET/2_original_$t" ]]; then
            echo "2_original_$t exists, skipping it"
            continue
        fi
        for f in "$SOURCE"/$t/*; do
            mkdir -p "$TARGET/2_original_$t"
            ln -s -r "$f" "$TARGET/2_original_$t/"
        done
    done

fi
